# ════════════════════════════════════════════════════
# .gitignore — что НЕ заливать в GitHub
# ════════════════════════════════════════════════════

# ── СЕКРЕТЫ — НИКОГДА в git! ────────────────────────
.env
.env.prod
.env.local
*.secret

# .env.dev и .env.example — ЗАЛИВАЕМ (без реальных ключей)
# Убедитесь что там нет реальных токенов!

# ── Базы данных ──────────────────────────────────────
*.db
*.sqlite
*.sqlite3
db/
db-dev/
db-prod/

# ── Логи ─────────────────────────────────────────────
logs/
*.log
*.log.*

# ── Резервные копии ───────────────────────────────────
backups/
*.bak

# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Виртуальное окружение ─────────────────────────────
venv/
.venv/
env/
ENV/

# ── IDE / редакторы ───────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker volumes (локальные данные) ─────────────────
volumes/

# ── Временные файлы ───────────────────────────────────
*.tmp
*.temp
.cache/
cloudflared.deb
.env.dev.backup
*.deb
